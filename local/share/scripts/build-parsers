#!/usr/bin/env bash
set -euo pipefail

# Check if parsers.lua parameter is provided
if [ $# -eq 0 ]; then
  echo "Error: parsers.lua path is required."
  echo "Usage: $0 <parsers.lua>"
  exit 1
fi

PARSERS_LUA="$1"

# Check if file exists
if [ ! -f "$PARSERS_LUA" ]; then
  echo "Error: File not found: $PARSERS_LUA"
  exit 1
fi

# Extract install_info fields for a language from parsers.lua
get_parser_info() {
  local lang="$1"
  luajit -e "
    local p = dofile('$PARSERS_LUA')
    local entry = p['$lang']
    if not entry or not entry.install_info then
      io.stderr:write('No entry for $lang in parsers.lua\n')
      os.exit(1)
    end
    local info = entry.install_info
    print(info.revision)
    print(info.url)
    print(info.location or '.')
  "
}

# Function to build parser
build_parser_from_lua() {
  local lang="$1"
  shift

  local info
  info=$(get_parser_info "$lang")
  local revision url subdirectory
  revision=$(echo "$info" | sed -n '1p')
  url=$(echo "$info" | sed -n '2p')
  subdirectory=$(echo "$info" | sed -n '3p')

  local args=()
  if [ "$subdirectory" != "." ]; then
    args+=(--subdirectory="$subdirectory")
  fi
  args+=("$@")

  build-parser "$lang" "$url" "$revision" ${args[@]+"${args[@]}"}
}

build_parser_from_lua bash
build_parser_from_lua css
build_parser_from_lua dockerfile
build_parser_from_lua dot
build_parser_from_lua git_rebase
build_parser_from_lua gitcommit
build_parser_from_lua gitignore
build_parser_from_lua go
build_parser_from_lua hcl
build_parser_from_lua html
build_parser_from_lua hurl
build_parser_from_lua java
build_parser_from_lua javascript
build_parser_from_lua json
build_parser_from_lua lua
build_parser_from_lua make
build_parser_from_lua markdown
build_parser_from_lua markdown_inline
build_parser_from_lua python
build_parser_from_lua regex
build_parser_from_lua ssh_config
build_parser_from_lua typescript --npm-install
build_parser_from_lua vim
build_parser_from_lua yaml
